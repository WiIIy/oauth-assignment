generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  image String?
  role  String  @default("viewer")
  theme String  @default("light")
}

model AllowedEmail {
  id    String  @id @default(cuid())
  email String  @unique
  role  String  @default("viewer") // "viewer" atau "editor"
}

